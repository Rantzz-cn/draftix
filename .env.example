# ─── DRAFTIX server config ───────────────────────────
# Copy to .env (gitignored) and adjust per environment.

# Port to bind (default 3000, auto-retries up to +30 if busy unless explicit).
PORT=3000

# Public origin(s) allowed to talk to the WebSocket / API.
# Comma-separated. Leave empty during local dev to allow any origin.
# When deployed at draftix.tech, set:
ALLOWED_ORIGINS=https://draftix.tech,https://www.draftix.tech

# Trust X-Forwarded-For (set to "1" when running behind a reverse proxy
# like Nginx / Caddy / Cloudflare so rate limiting uses the real client IP).
TRUST_PROXY=1

# Cap a single captain's window before auto-ban kicks in. Milliseconds.
# Default 30000 (30 seconds).
TURN_TIMEOUT_MS=30000

# How long a disconnected player keeps their seat (captain/host/team) before
# the server actually frees it. Lets a refresh, dropped Wi-Fi, or quick tab
# close survive without losing the role. Milliseconds. Default 60000 (60s).
RECONNECT_GRACE_MS=60000

# Hard caps. Generous defaults; tighten if abused.
MAX_SESSIONS=5000
MAX_CLIENTS_PER_SESSION=32

# Surfaced via /healthz so monitoring can verify deploy version.
APP_VERSION=1.0.0
